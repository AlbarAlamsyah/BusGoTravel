    <property name="net.sf.jasperreports.default.font.name" value="SansSerif"/>
    <style name="HeaderStyle" fontName="SansSerif" fontSize="9" isBold="true" mode="Opaque" backcolor="#1E3A8A" forecolor="#FFFFFF"/>
    <style name="DetailStyle" fontName="SansSerif" fontSize="9"/>

    <queryString><![CDATA[SELECT nama_lengkap, username, role, status, created_at FROM users ORDER BY id_user DESC]]></queryString>
    <field name="nama_lengkap" class="java.lang.String"/>
    <field name="username" class="java.lang.String"/>
    <field name="role" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="created_at" class="java.sql.Timestamp"/>

    <title>
