<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_transaksi" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="22222222-2222-2222-2222-222222222222">
    <property name="net.sf.jasperreports.default.font.name" value="SansSerif"/>
    <style name="HeaderStyle" fontName="SansSerif" fontSize="8" isBold="true" mode="Opaque" backcolor="#1E3A8A" forecolor="#FFFFFF"/>
    <style name="DetailStyle" fontName="SansSerif" fontSize="8"/>

    <parameter name="tanggal_awal" class="java.sql.Date"/>
    <parameter name="tanggal_akhir" class="java.sql.Date"/>

    <queryString><![CDATA[
        SELECT t.kode_transaksi, t.tanggal_transaksi, p.nama_penumpang,
               CONCAT(tj.kota_asal, ' - ', tj.kota_tujuan) AS rute,
               a.nama_bus, t.kelas_tiket, t.harga_tiket, t.jumlah_tiket,
               t.subtotal, t.diskon, t.total_bayar, u.username
        FROM transaksi t
        JOIN tujuan tj ON t.id_tujuan = tj.id_tujuan
        JOIN armada a ON t.id_armada = a.id_armada
        JOIN penumpang p ON t.id_penumpang = p.id_penumpang
        JOIN users u ON t.id_user = u.id_user
        WHERE t.tanggal_transaksi BETWEEN $P{tanggal_awal} AND $P{tanggal_akhir}
        ORDER BY t.id_transaksi DESC
    ]]></queryString>

    <field name="kode_transaksi" class="java.lang.String"/>
    <field name="tanggal_transaksi" class="java.sql.Date"/>
    <field name="nama_penumpang" class="java.lang.String"/>
    <field name="rute" class="java.lang.String"/>
    <field name="nama_bus" class="java.lang.String"/>
    <field name="kelas_tiket" class="java.lang.String"/>
    <field name="harga_tiket" class="java.math.BigDecimal"/>
    <field name="jumlah_tiket" class="java.lang.Integer"/>
    <field name="subtotal" class="java.math.BigDecimal"/>
    <field name="diskon" class="java.math.BigDecimal"/>
    <field name="total_bayar" class="java.math.BigDecimal"/>
    <field name="username" class="java.lang.String"/>

    <variable name="grand_total_tiket" class="java.lang.Integer" calculation="Sum"><variableExpression><![CDATA[$F{jumlah_tiket}]]></variableExpression></variable>
    <variable name="grand_total_bayar" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{total_bayar}]]></variableExpression></variable>

    <title><band height="95">
        <rectangle><reportElement x="0" y="0" width="802" height="72" backcolor="#1E3A8A" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
        <staticText><reportElement x="0" y="12" width="802" height="24" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="18" isBold="true"/></textElement><text><![CDATA[BUSGO TRAVEL]]></text></staticText>
        <staticText><reportElement x="0" y="38" width="802" height="18" forecolor="#E0ECFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement><text><![CDATA[LAPORAN TRANSAKSI TIKET]]></text></staticText>
        <textField><reportElement x="0" y="58" width="802" height="14" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement><textFieldExpression><![CDATA["Periode: " + $P{tanggal_awal} + " s/d " + $P{tanggal_akhir}]]></textFieldExpression></textField>
    </band></title>

    <columnHeader><band height="32"><rectangle><reportElement x="0" y="0" width="802" height="28" backcolor="#1E3A8A" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
        <staticText><reportElement style="HeaderStyle" x="0" y="0" width="65" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Kode]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="65" y="0" width="70" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Tanggal]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="135" y="0" width="105" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Penumpang]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="240" y="0" width="110" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Rute]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="350" y="0" width="90" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Bus]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="440" y="0" width="60" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><text><![CDATA[Kelas]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="500" y="0" width="35" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Center" verticalAlignment="Middle"/><text><![CDATA[Qty]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="535" y="0" width="85" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Subtotal]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="620" y="0" width="75" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Diskon]]></text></staticText>
        <staticText><reportElement style="HeaderStyle" x="695" y="0" width="107" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Total]]></text></staticText>
    </band></columnHeader>

    <detail><band height="30"><rectangle><reportElement x="0" y="0" width="802" height="28" backcolor="#FFFFFF" mode="Opaque"/><graphicElement><pen lineWidth="0.25" lineColor="#E2E8F0"/></graphicElement></rectangle>
        <textField><reportElement style="DetailStyle" x="0" y="0" width="65" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{kode_transaksi}]]></textFieldExpression></textField>
        <textField pattern="dd-MM-yyyy"><reportElement style="DetailStyle" x="65" y="0" width="70" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{tanggal_transaksi}]]></textFieldExpression></textField>
        <textField><reportElement style="DetailStyle" x="135" y="0" width="105" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{nama_penumpang}]]></textFieldExpression></textField>
        <textField><reportElement style="DetailStyle" x="240" y="0" width="110" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{rute}]]></textFieldExpression></textField>
        <textField><reportElement style="DetailStyle" x="350" y="0" width="90" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{nama_bus}]]></textFieldExpression></textField>
        <textField><reportElement style="DetailStyle" x="440" y="0" width="60" height="28"/><box leftPadding="4" rightPadding="4"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{kelas_tiket}]]></textFieldExpression></textField>
        <textField><reportElement style="DetailStyle" x="500" y="0" width="35" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Center" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{jumlah_tiket}]]></textFieldExpression></textField>
        <textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="535" y="0" width="85" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{subtotal}]]></textFieldExpression></textField>
        <textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="620" y="0" width="75" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{diskon}]]></textFieldExpression></textField>
        <textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="695" y="0" width="107" height="28"/><box leftPadding="4" rightPadding="4"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{total_bayar}]]></textFieldExpression></textField>
    </band></detail>

    <pageFooter><band height="28"><line><reportElement x="0" y="0" width="802" height="1" forecolor="#E2E8F0"/></line><staticText><reportElement x="0" y="7" width="300" height="18" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[BusGo Travel - Laporan Transaksi Tiket]]></text></staticText><textField><reportElement x="620" y="7" width="182" height="18" forecolor="#64748B"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>

    <summary><band height="82"><rectangle><reportElement x="500" y="12" width="302" height="55" backcolor="#EFF6FF" mode="Opaque"/><graphicElement><pen lineWidth="0.5" lineColor="#BFDBFE"/></graphicElement></rectangle><staticText><reportElement x="520" y="20" width="110" height="18" forecolor="#1E3A8A"/><textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement><text><![CDATA[Total Pendapatan]]></text></staticText><textField pattern="Rp #,##0"><reportElement x="630" y="18" width="152" height="22" forecolor="#1E3A8A"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{grand_total_bayar}]]></textFieldExpression></textField><textField><reportElement x="520" y="43" width="262" height="14" forecolor="#475569"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Total Tiket Terjual: " + $V{grand_total_tiket} + " tiket"]]></textFieldExpression></textField></band></summary>

    <noData><band height="180"><staticText><reportElement x="0" y="40" width="802" height="30"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="16" isBold="true"/></textElement><text><![CDATA[BUSGO TRAVEL]]></text></staticText><staticText><reportElement x="0" y="80" width="802" height="25" forecolor="#64748B"/><textElement textAlignment="Center" verticalAlignment="Middle"/><text><![CDATA[Tidak ada data transaksi pada periode yang dipilih.]]></text></staticText></band></noData>
