            <staticText>
                <reportElement style="HeaderStyle" x="440" y="0" width="120" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <text><![CDATA[Bisnis]]></text>
            </staticText>
            <staticText>
                <reportElement style="HeaderStyle" x="560" y="0" width="130" height="28"/>
