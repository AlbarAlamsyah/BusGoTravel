            <textField isStretchWithOverflow="true">
                <reportElement style="DetailStyle" x="0" y="0" width="90" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{kode_tujuan}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement style="DetailStyle" x="90" y="0" width="115" height="28"/>
