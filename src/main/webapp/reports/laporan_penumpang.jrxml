            <textField isStretchWithOverflow="true">
                <reportElement style="DetailStyle" x="325" y="0" width="120" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{no_hp}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement style="DetailStyle" x="445" y="0" width="235" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{alamat}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
