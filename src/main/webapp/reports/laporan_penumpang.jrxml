            <staticText>
                <reportElement style="HeaderStyle" x="0" y="0" width="155" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[NIK]]></text>
            </staticText>
            <staticText>
                <reportElement style="HeaderStyle" x="155" y="0" width="170" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[Nama Penumpang]]></text>
            </staticText>
            <staticText>
                <reportElement style="HeaderStyle" x="325" y="0" width="120" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[No HP]]></text>
            </staticText>
            <staticText>
                <reportElement style="HeaderStyle" x="445" y="0" width="235" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[Alamat]]></text>
            </staticText>
            <staticText>
                <reportElement style="HeaderStyle" x="680" y="0" width="122" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Jenis Kelamin]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="30">
            <rectangle><reportElement x="0" y="0" width="802" height="28" backcolor="#FFFFFF" mode="Opaque"/><graphicElement><pen lineWidth="0.25" lineColor="#E2E8F0"/></graphicElement></rectangle>

            <textField isStretchWithOverflow="true">
                <reportElement style="DetailStyle" x="0" y="0" width="155" height="28"/>
                <box leftPadding="6" rightPadding="6"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{nik}]]></textFieldExpression>
