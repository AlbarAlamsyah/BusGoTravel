<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_pendapatan" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="33333333-3333-3333-3333-333333333333">
    <property name="net.sf.jasperreports.default.font.name" value="SansSerif"/>
    <style name="HeaderStyle" fontName="SansSerif" fontSize="9" isBold="true" mode="Opaque" backcolor="#1E3A8A" forecolor="#FFFFFF"/>
    <style name="DetailStyle" fontName="SansSerif" fontSize="9"/>
    <parameter name="tanggal_awal" class="java.sql.Date"/>
    <parameter name="tanggal_akhir" class="java.sql.Date"/>
    <queryString><![CDATA[
        SELECT tanggal_transaksi, COUNT(*) AS jumlah_transaksi, SUM(jumlah_tiket) AS total_tiket,
               SUM(subtotal) AS total_subtotal, SUM(diskon) AS total_diskon, SUM(total_bayar) AS total_pendapatan
        FROM transaksi
        WHERE tanggal_transaksi BETWEEN $P{tanggal_awal} AND $P{tanggal_akhir}
        GROUP BY tanggal_transaksi
        ORDER BY tanggal_transaksi DESC
    ]]></queryString>
    <field name="tanggal_transaksi" class="java.sql.Date"/>
    <field name="jumlah_transaksi" class="java.lang.Long"/>
    <field name="total_tiket" class="java.math.BigDecimal"/>
    <field name="total_subtotal" class="java.math.BigDecimal"/>
    <field name="total_diskon" class="java.math.BigDecimal"/>
    <field name="total_pendapatan" class="java.math.BigDecimal"/>
    <variable name="grand_total_transaksi" class="java.lang.Long" calculation="Sum"><variableExpression><![CDATA[$F{jumlah_transaksi}]]></variableExpression></variable>
    <variable name="grand_total_tiket" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{total_tiket}]]></variableExpression></variable>
    <variable name="grand_total_pendapatan" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{total_pendapatan}]]></variableExpression></variable>

    <title><band height="95"><rectangle><reportElement x="0" y="0" width="802" height="72" backcolor="#1E3A8A" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle><staticText><reportElement x="0" y="12" width="802" height="24" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="18" isBold="true"/></textElement><text><![CDATA[BUSGO TRAVEL]]></text></staticText><staticText><reportElement x="0" y="38" width="802" height="18" forecolor="#E0ECFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement><text><![CDATA[LAPORAN PENDAPATAN]]></text></staticText><textField><reportElement x="0" y="58" width="802" height="14" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement><textFieldExpression><![CDATA["Periode: " + $P{tanggal_awal} + " s/d " + $P{tanggal_akhir}]]></textFieldExpression></textField></band></title>

    <columnHeader><band height="32"><rectangle><reportElement x="0" y="0" width="802" height="28" backcolor="#1E3A8A" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle><staticText><reportElement style="HeaderStyle" x="0" y="0" width="120" height="28"/><box leftPadding="6" rightPadding="6"/><textElement verticalAlignment="Middle"/><text><![CDATA[Tanggal]]></text></staticText><staticText><reportElement style="HeaderStyle" x="120" y="0" width="130" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Center" verticalAlignment="Middle"/><text><![CDATA[Jumlah Transaksi]]></text></staticText><staticText><reportElement style="HeaderStyle" x="250" y="0" width="100" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Center" verticalAlignment="Middle"/><text><![CDATA[Total Tiket]]></text></staticText><staticText><reportElement style="HeaderStyle" x="350" y="0" width="140" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Subtotal]]></text></staticText><staticText><reportElement style="HeaderStyle" x="490" y="0" width="130" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Diskon]]></text></staticText><staticText><reportElement style="HeaderStyle" x="620" y="0" width="182" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[Pendapatan]]></text></staticText></band></columnHeader>

    <detail><band height="30"><rectangle><reportElement x="0" y="0" width="802" height="28" backcolor="#FFFFFF" mode="Opaque"/><graphicElement><pen lineWidth="0.25" lineColor="#E2E8F0"/></graphicElement></rectangle><textField pattern="dd-MM-yyyy"><reportElement style="DetailStyle" x="0" y="0" width="120" height="28"/><box leftPadding="6" rightPadding="6"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{tanggal_transaksi}]]></textFieldExpression></textField><textField><reportElement style="DetailStyle" x="120" y="0" width="130" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Center" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{jumlah_transaksi}]]></textFieldExpression></textField><textField><reportElement style="DetailStyle" x="250" y="0" width="100" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Center" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{total_tiket}]]></textFieldExpression></textField><textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="350" y="0" width="140" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{total_subtotal}]]></textFieldExpression></textField><textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="490" y="0" width="130" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{total_diskon}]]></textFieldExpression></textField><textField pattern="Rp #,##0"><reportElement style="DetailStyle" x="620" y="0" width="182" height="28"/><box leftPadding="6" rightPadding="6"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{total_pendapatan}]]></textFieldExpression></textField></band></detail>

    <pageFooter><band height="28"><line><reportElement x="0" y="0" width="802" height="1" forecolor="#E2E8F0"/></line><staticText><reportElement x="0" y="7" width="300" height="18" forecolor="#64748B"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[BusGo Travel - Laporan Pendapatan]]></text></staticText><textField><reportElement x="620" y="7" width="182" height="18" forecolor="#64748B"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>

    <summary><band height="88"><rectangle><reportElement x="325" y="12" width="477" height="60" backcolor="#EFF6FF" mode="Opaque"/><graphicElement><pen lineWidth="0.5" lineColor="#BFDBFE"/></graphicElement></rectangle><staticText><reportElement x="345" y="22" width="190" height="18" forecolor="#1E3A8A"/><textElement verticalAlignment="Middle"><font size="11" isBold="true"/></textElement><text><![CDATA[Grand Total Pendapatan]]></text></staticText><textField pattern="Rp #,##0"><reportElement x="535" y="20" width="247" height="24" forecolor="#1E3A8A"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{grand_total_pendapatan}]]></textFieldExpression></textField><textField><reportElement x="345" y="47" width="210" height="15" forecolor="#475569"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Total Transaksi: " + $V{grand_total_transaksi} + " transaksi"]]></textFieldExpression></textField><textField><reportElement x="555" y="47" width="227" height="15" forecolor="#475569"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Total Tiket: " + $V{grand_total_tiket} + " tiket"]]></textFieldExpression></textField></band></summary>

    <noData><band height="180"><staticText><reportElement x="0" y="40" width="802" height="30"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="16" isBold="true"/></textElement><text><![CDATA[BUSGO TRAVEL]]></text></staticText><staticText><reportElement x="0" y="80" width="802" height="25" forecolor="#64748B"/><textElement textAlignment="Center" verticalAlignment="Middle"/><text><![CDATA[Tidak ada data pendapatan pada periode yang dipilih.]]></text></staticText></band></noData>
</jasperReport>
